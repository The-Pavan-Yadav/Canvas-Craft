        <path
            android:fillColor="#F43F5E"
            android:pathData="M 54 44 A 5 5 0 1 1 54 54 A 5 5 0 1 1 54 44 Z" />
    </group>

    <!-- Card 3 (Center foreground card, perfectly aligned, fuchsia/indigo gradient) -->
