            android:pathData="M 39 34 h 30 a 6 6 0 0 1 6 6 v 40 a 6 6 0 0 1 -6 6 h -30 a 6 6 0 0 1 -6 -6 v -40 a 6 6 0 0 1 6 -6 Z" />
